# Copy to backend/.env for local development.
# Never commit the actual .env file.

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg:///pnu_pathfinder

# ── Student JWT Auth ──────────────────────────────────────────────
# REQUIRED in production — change to a long random secret.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=pnu-pathfinder-local-dev-secret

# ── Admin Credentials ─────────────────────────────────────────────
# REQUIRED in production — replace all three values.
ADMIN_ID=root
ADMIN_PASSWORD=3011
ADMIN_TOKEN=pnu-pathfinder-admin-local-token
